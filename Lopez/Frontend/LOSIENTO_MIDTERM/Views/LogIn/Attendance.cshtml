<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Attendance - AMS</title>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar" id="sidebar"></aside>
        <div class="main-content">
            <div class="topbar" id="topbar"></div>
            <div class="page-content">

                <div class="table-header">
                    <div><h2>Attendance</h2></div>
                    <button class="btn-add" onclick="openModal()">ADD</button>
                </div>

                <table class="data-table">
                    <thead>
                        <tr><th>STUDENT</th><th>ID</th><th>PROGRAM</th><th>P</th><th>A</th><th>L</th><th>REMARKS</th><th></th></tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination">
                    <button onclick="prevPage()">&#60;</button>
                    <span id="pageInfo">Page 1</span>
                    <button onclick="nextPage()">&#62;</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ADD MODAL -->
    <div class="modal-overlay" id="modal">
        <div class="modal">
            <button class="close-modal" onclick="closeModal()">&#10005;</button>
            <h3>Add Attendance Record</h3>
            <div class="form-group"><label>Student Name</label><input type="text" id="m-name" placeholder="Full Name" /></div>
            <div class="form-group"><label>Student ID</label><input type="text" id="m-id" placeholder="ID Number" /></div>
            <div class="form-group">
                <label>Program</label>
                <select id="m-program"><option value="BSIT">BSIT</option><option value="BSME">BSME</option></select>
            </div>
            <div class="form-group"><label>Remarks</label><input type="text" id="m-remarks" placeholder="Remarks (optional)" /></div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeModal()">Cancel</button>
                <button class="btn-save" onclick="addRecord()">Save</button>
            </div>
        </div>
    </div>

    <!-- EDIT MODAL -->
    <div class="modal-overlay" id="editModal">
        <div class="modal">
            <button class="close-modal" onclick="closeEditModal()">&#10005;</button>
            <h3>Edit Attendance Record</h3>
            <div class="form-group"><label>Student Name</label><input type="text" id="e-name" placeholder="Full Name" /></div>
            <div class="form-group"><label>Student ID</label><input type="text" id="e-id" placeholder="ID Number" /></div>
            <div class="form-group">
                <label>Program</label>
                <select id="e-program"><option value="BSIT">BSIT</option><option value="BSME">BSME</option></select>
            </div>
            <div class="form-group"><label>Remarks</label><input type="text" id="e-remarks" placeholder="Remarks" /></div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeEditModal()">Cancel</button>
                <button class="btn-save" onclick="saveEdit()">Update</button>
            </div>
        </div>
    </div>

    <script src="~/js/layout.js"></script>
    <script>
        renderLayout('Attendance');

        var currentPage = 1, rowsPerPage = 10, editIndex = -1;

        var records = [
            { name: 'Moreno Juqjun',    id: '902182', program: 'BSIT', p: false, a: false, l: false, remarks: '' },
            { name: 'Kenwell Montekun', id: '902182', program: 'BSIT', p: false, a: false, l: false, remarks: '' },
            { name: 'Kenwell Montekun', id: '902182', program: 'BSIT', p: false, a: false, l: false, remarks: '' },
            { name: 'Kenwell Montekun', id: '902182', program: 'BSIT', p: false, a: false, l: false, remarks: '' },
            { name: 'Kenwell Montekun', id: '902182', program: 'BSIT', p: false, a: false, l: false, remarks: '' },
            { name: 'Kenwell Montekun', id: '902182', program: 'BSIT', p: false, a: false, l: false, remarks: '' },
        ];

        function toggleAtt(gi, type) {
            if (type === 'p') records[gi].p = !records[gi].p;
            if (type === 'a') records[gi].a = !records[gi].a;
            if (type === 'l') records[gi].l = !records[gi].l;
            renderTable();
        }

        function renderTable() {
            var start = (currentPage - 1) * rowsPerPage;
            var slice = records.slice(start, start + rowsPerPage);
            document.getElementById('tableBody').innerHTML = slice.map(function(r, i) {
                var gi = start + i;
                return '<tr>' +
                    '<td>' + r.name + '</td><td>' + r.id + '</td><td>' + r.program + '</td>' +
                    '<td><span class="att-btn ' + (r.p ? 'selected-p' : '') + '" onclick="toggleAtt(' + gi + ',\'p\')">P</span></td>' +
                    '<td><span class="att-btn ' + (r.a ? 'selected-a' : '') + '" onclick="toggleAtt(' + gi + ',\'a\')">A</span></td>' +
                    '<td><span class="att-btn ' + (r.l ? 'selected-l' : '') + '" onclick="toggleAtt(' + gi + ',\'l\')">L</span></td>' +
                    '<td><input class="remarks-input" type="text" value="' + r.remarks + '" placeholder="put here" onchange="records[' + gi + '].remarks=this.value" /></td>' +
                    '<td style="display:flex;gap:4px;align-items:center;">' +
                    '<button class="edit-btn" onclick="openEditModal(' + gi + ')"><img src="/Assets/edit_icon.png" alt="edit" /></button>' +
                    '<button class="delete-btn" onclick="deleteRow(' + gi + ')"><img src="/Assets/delete_icon.png" alt="delete" /></button>' +
                    '</td></tr>';
            }).join('');
            var total = Math.max(1, Math.ceil(records.length / rowsPerPage));
            document.getElementById('pageInfo').textContent = 'Page ' + currentPage + ' / ' + total;
        }

        function deleteRow(idx) { if (confirm('Delete this record?')) { records.splice(idx, 1); renderTable(); } }

        function openEditModal(idx) {
            editIndex = idx;
            var r = records[idx];
            document.getElementById('e-name').value = r.name;
            document.getElementById('e-id').value = r.id;
            document.getElementById('e-program').value = r.program;
            document.getElementById('e-remarks').value = r.remarks;
            document.getElementById('editModal').classList.add('open');
        }
        function closeEditModal() { document.getElementById('editModal').classList.remove('open'); }
        function saveEdit() {
            var name = document.getElementById('e-name').value.trim();
            var id = document.getElementById('e-id').value.trim();
            var program = document.getElementById('e-program').value;
            var remarks = document.getElementById('e-remarks').value.trim();
            if (!name || !id) { alert('Please fill all fields.'); return; }
            records[editIndex].name = name;
            records[editIndex].id = id;
            records[editIndex].program = program;
            records[editIndex].remarks = remarks;
            renderTable(); closeEditModal();
        }

        function prevPage() { if (currentPage > 1) { currentPage--; renderTable(); } }
        function nextPage() { var t = Math.ceil(records.length / rowsPerPage); if (currentPage < t) { currentPage++; renderTable(); } }
        function openModal() { document.getElementById('modal').classList.add('open'); }
        function closeModal() { document.getElementById('modal').classList.remove('open'); }
        function addRecord() {
            var name = document.getElementById('m-name').value.trim();
            var id = document.getElementById('m-id').value.trim();
            var program = document.getElementById('m-program').value;
            var remarks = document.getElementById('m-remarks').value.trim();
            if (!name || !id) { alert('Please enter student name and ID.'); return; }
            records.push({ name: name, id: id, program: program, p: false, a: false, l: false, remarks: remarks });
            renderTable(); closeModal();
            ['m-name', 'm-id', 'm-remarks'].forEach(function(f) { document.getElementById(f).value = ''; });
        }

        renderTable();
    </script>
</body>
</html>