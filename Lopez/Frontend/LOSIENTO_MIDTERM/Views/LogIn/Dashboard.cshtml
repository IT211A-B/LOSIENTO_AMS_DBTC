<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - AMS</title>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar" id="sidebar"></aside>
        <div class="main-content">
            <div class="topbar" id="topbar"></div>
            <div class="page-content">
                <div class="dashboard-stats">
                    <div class="stat-card teal">
                        <div class="stat-num" id="dash-students">0</div>
                        <div class="stat-label">Total Students</div>
                    </div>
                    <div class="stat-card green">
                        <div class="stat-num" id="dash-teachers">0</div>
                        <div class="stat-label">Total Teachers</div>
                    </div>
                    <div class="stat-card teal">
                        <div class="stat-num" id="dash-courses">0</div>
                        <div class="stat-label">Courses</div>
                    </div>
                </div>
                <div class="dashboard-charts">
                    <div class="chart-box enrollment">Enrollment Graph</div>
                    <div class="chart-box attendance">Attendance Rate</div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/layout.js"></script>
    <script>
        renderLayout('Dashboard');
        updateDashboardCounts();
    </script>
</body>
</html>
