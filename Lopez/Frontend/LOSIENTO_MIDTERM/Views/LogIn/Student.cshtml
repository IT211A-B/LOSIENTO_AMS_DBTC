<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Students - AMS</title>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar" id="sidebar"></aside>
        <div class="main-content">
            <div class="topbar" id="topbar"></div>
            <div class="page-content">

                <div class="table-header">
                    <div>
                        <h2>Students</h2>
                        <div class="subtitle" id="stu-sub">Bachelor of Science in Information and Technology</div>
                    </div>
                    <button class="btn-add" onclick="openModal()">ADD</button>
                </div>

                <div class="tab-row">
                    <button class="tab-btn active" id="tab-bsit" onclick="switchTab('BSIT')">BSIT</button>
                    <button class="tab-btn" id="tab-bsme" onclick="switchTab('BSME')">BSME</button>
                </div>

                <table class="data-table">
                    <thead>
                        <tr><th>STUDENT</th><th>ID</th><th>EMAIL</th><th>COURSE</th><th>Year Level</th><th></th></tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination">
                    <button onclick="prevPage()">&#60;</button>
                    <span id="pageInfo">Page 1</span>
                    <button onclick="nextPage()">&#62;</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ADD MODAL -->
    <div class="modal-overlay" id="modal">
        <div class="modal">
            <button class="close-modal" onclick="closeModal()">&#10005;</button>
            <h3>Add Student</h3>
            <div class="form-group"><label>Full Name</label><input type="text" id="m-name" placeholder="Full Name" /></div>
            <div class="form-group"><label>Student ID</label><input type="text" id="m-id" placeholder="ID Number" /></div>
            <div class="form-group"><label>Email</label><input type="email" id="m-email" placeholder="Email Address" /></div>
            <div class="form-group">
                <label>Course</label>
                <select id="m-course"><option value="BSIT">BSIT</option><option value="BSME">BSME</option></select>
            </div>
            <div class="form-group">
                <label>Year Level</label>
                <select id="m-year"><option>1</option><option>2</option><option>3</option><option>4</option></select>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeModal()">Cancel</button>
                <button class="btn-save" onclick="addStudent()">Save</button>
            </div>
        </div>
    </div>

    <!-- EDIT MODAL -->
    <div class="modal-overlay" id="editModal">
        <div class="modal">
            <button class="close-modal" onclick="closeEditModal()">&#10005;</button>
            <h3>Edit Student</h3>
            <div class="form-group"><label>Full Name</label><input type="text" id="e-name" placeholder="Full Name" /></div>
            <div class="form-group"><label>Student ID</label><input type="text" id="e-id" placeholder="ID Number" /></div>
            <div class="form-group"><label>Email</label><input type="email" id="e-email" placeholder="Email Address" /></div>
            <div class="form-group">
                <label>Course</label>
                <select id="e-course"><option value="BSIT">BSIT</option><option value="BSME">BSME</option></select>
            </div>
            <div class="form-group">
                <label>Year Level</label>
                <select id="e-year"><option>1</option><option>2</option><option>3</option><option>4</option></select>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeEditModal()">Cancel</button>
                <button class="btn-save" onclick="saveEdit()">Update</button>
            </div>
        </div>
    </div>

    <script src="~/js/layout.js"></script>
    <script>
        renderLayout('Student');

        var courseNames = {
            BSIT: 'Bachelor of Science in Information and Technology',
            BSME: 'Bachelor of Science in Mechanical Engineering'
        };

        var currentTab = 'BSIT';
        var currentPage = 1;
        var rowsPerPage = 10;
        var editIndex = -1;

        function switchTab(tab) {
            currentTab = tab;
            currentPage = 1;
            document.getElementById('tab-bsit').classList.toggle('active', tab === 'BSIT');
            document.getElementById('tab-bsme').classList.toggle('active', tab === 'BSME');
            document.getElementById('stu-sub').textContent = courseNames[tab];
            renderTable();
        }

        function renderTable() {
            var data = window.AMS.students[currentTab];
            var start = (currentPage - 1) * rowsPerPage;
            var slice = data.slice(start, start + rowsPerPage);
            document.getElementById('tableBody').innerHTML = slice.map(function(s, i) {
                var gi = start + i;
                return '<tr><td>' + s.name + '</td><td>' + s.id + '</td><td>' + s.email + '</td><td>' + s.course + '</td><td>' + s.year + '</td>' +
                    '<td style="display:flex;gap:4px;align-items:center;">' +
                    '<button class="edit-btn" onclick="openEditModal(' + gi + ')"><img src="/Assets/edit_icon.png" alt="edit" /></button>' +
                    '<button class="delete-btn" onclick="deleteRow(' + gi + ')"><img src="/Assets/delete_icon.png" alt="delete" /></button>' +
                    '</td></tr>';
            }).join('');
            var total = Math.max(1, Math.ceil(data.length / rowsPerPage));
            document.getElementById('pageInfo').textContent = 'Page ' + currentPage + ' / ' + total;
        }

        function deleteRow(idx) {
            if (confirm('Delete this student?')) {
                window.AMS.students[currentTab].splice(idx, 1);
                renderTable();
            }
        }

        function openEditModal(idx) {
            editIndex = idx;
            var s = window.AMS.students[currentTab][idx];
            document.getElementById('e-name').value = s.name;
            document.getElementById('e-id').value = s.id;
            document.getElementById('e-email').value = s.email;
            document.getElementById('e-course').value = s.course;
            document.getElementById('e-year').value = s.year;
            document.getElementById('editModal').classList.add('open');
        }

        function closeEditModal() { document.getElementById('editModal').classList.remove('open'); }

        function saveEdit() {
            var name = document.getElementById('e-name').value.trim();
            var id = document.getElementById('e-id').value.trim();
            var email = document.getElementById('e-email').value.trim();
            var course = document.getElementById('e-course').value;
            var year = parseInt(document.getElementById('e-year').value);
            if (!name || !id || !email) { alert('Please fill all fields.'); return; }
            window.AMS.students[currentTab][editIndex] = { name: name, id: id, email: email, course: course, year: year };
            renderTable();
            closeEditModal();
        }

        function prevPage() { if (currentPage > 1) { currentPage--; renderTable(); } }
        function nextPage() {
            var total = Math.ceil(window.AMS.students[currentTab].length / rowsPerPage);
            if (currentPage < total) { currentPage++; renderTable(); }
        }

        function openModal() { document.getElementById('modal').classList.add('open'); }
        function closeModal() { document.getElementById('modal').classList.remove('open'); }

        function addStudent() {
            var name = document.getElementById('m-name').value.trim();
            var id = document.getElementById('m-id').value.trim();
            var email = document.getElementById('m-email').value.trim();
            var course = document.getElementById('m-course').value;
            var year = parseInt(document.getElementById('m-year').value);
            if (!name || !id || !email) { alert('Please fill all fields.'); return; }
            window.AMS.students[course].push({ name: name, id: id, email: email, course: course, year: year });
            if (currentTab !== course) switchTab(course);
            else renderTable();
            closeModal();
            document.getElementById('m-name').value = '';
            document.getElementById('m-id').value = '';
            document.getElementById('m-email').value = '';
        }

        renderTable();
    </script>
</body>
</html>