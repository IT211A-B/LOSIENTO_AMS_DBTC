<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - AMS</title>
    <link rel="stylesheet" href="~/css/styles.css" />
    <style>
        .login-page {
            min-height: 100vh;
            background-color: #1a2744;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        /* Faded background logo */
        .login-bg-logo {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 520px;
            height: 520px;
            object-fit: contain;
            opacity: 0.07;
            pointer-events: none;
            user-select: none;
        }

        /* Small corner logo */
        .login-corner-logo {
            position: absolute;
            top: 20px;
            left: 20px;
            width: 65px;
            height: 65px;
            object-fit: contain;
            z-index: 3;
        }

        .login-card {
            position: relative;
            z-index: 2;
            background: rgba(255, 255, 255, 0.93);
            border-radius: 14px;
            padding: 42px 38px;
            width: 380px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
        }

            .login-card h2 {
                text-align: center;
                font-size: 1.6rem;
                font-weight: 800;
                letter-spacing: 3px;
                margin-bottom: 28px;
                color: #111;
            }

            .login-card input {
                width: 100%;
                padding: 12px 14px;
                border: 1.5px solid #ccc;
                border-radius: 7px;
                font-size: 0.95rem;
                margin-bottom: 14px;
                background: #fff;
                color: #222;
                outline: none;
                transition: border-color 0.2s;
            }

                .login-card input:focus {
                    border-color: #1a6be0;
                }

        .forgot-link {
            display: block;
            text-align: right;
            font-size: 0.82rem;
            color: #1a6be0;
            text-decoration: underline;
            margin-top: -6px;
            margin-bottom: 18px;
            cursor: pointer;
        }

        .btn-login {
            width: 100%;
            padding: 12px;
            background: #1a2744;
            color: #fff;
            border: none;
            border-radius: 7px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            letter-spacing: 1px;
            transition: background 0.2s;
        }

            .btn-login:hover {
                background: #243a6e;
            }

        .login-footer {
            text-align: center;
            margin-top: 18px;
            font-size: 0.88rem;
            color: #444;
        }

            .login-footer a {
                color: #1a6be0;
                text-decoration: none;
                font-weight: 700;
            }

                .login-footer a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>
    <div class="login-page">
        <!-- Faded background logo -->
        <img src="/Assets/dbtc_LOGO.png" class="login-bg-logo" alt="" />

        <!-- Small corner logo -->
        <img src="/Assets/dbtc_LOGO.png" class="login-corner-logo" alt="DBTC Logo" />

        <!-- Login card -->
        <div class="login-card">
            <h2>WELCOME</h2>
            <input type="text" id="username" placeholder="Username" />
            <input type="password" id="password" placeholder="Password" />
            <span class="forgot-link" onclick="alert('Password reset not implemented.')">Forgot Password?</span>
            <button class="btn-login" onclick="doLogin()">Login</button>
            <p class="login-footer">Don't have an account? <a href="/LogIn/Register">sign up</a></p>
        </div>
    </div>

    <script>
        function doLogin() {
            var u = document.getElementById('username').value.trim();
            var p = document.getElementById('password').value.trim();
            if (!u || !p) { alert('Please enter your username and password.'); return; }
            sessionStorage.setItem('ams_user', u);
            window.location.href = '/LogIn/Dashboard';
        }
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') doLogin();
        });
    </script>
</body>
</html>