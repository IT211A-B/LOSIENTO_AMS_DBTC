<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Teachers - AMS</title>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar" id="sidebar"></aside>
        <div class="main-content">
            <div class="topbar" id="topbar"></div>
            <div class="page-content">

                <div class="table-header">
                    <div><h2>Teachers</h2></div>
                    <button class="btn-add" onclick="openModal()">ADD</button>
                </div>

                <table class="data-table">
                    <thead>
                        <tr><th>TEACHER</th><th>ID</th><th>SUBJECT</th><th>POSITION</th><th>DEPARTMENT</th><th></th></tr>
                    </thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination">
                    <button onclick="prevPage()">&#60;</button>
                    <span id="pageInfo">Page 1</span>
                    <button onclick="nextPage()">&#62;</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ADD MODAL -->
    <div class="modal-overlay" id="modal">
        <div class="modal">
            <button class="close-modal" onclick="closeModal()">&#10005;</button>
            <h3>Add Teacher</h3>
            <div class="form-group"><label>Full Name</label><input type="text" id="m-name" placeholder="Full Name" /></div>
            <div class="form-group"><label>ID</label><input type="text" id="m-id" placeholder="ID Number" /></div>
            <div class="form-group"><label>Subject</label><input type="text" id="m-subject" placeholder="Subject" /></div>
            <div class="form-group">
                <label>Position</label>
                <select id="m-position"><option>Professor</option><option>Instructor</option><option>Associate Professor</option></select>
            </div>
            <div class="form-group">
                <label>Department</label>
                <select id="m-dept"><option>IT</option><option>Engineering</option><option>Science</option><option>Math</option></select>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeModal()">Cancel</button>
                <button class="btn-save" onclick="addTeacher()">Save</button>
            </div>
        </div>
    </div>

    <!-- EDIT MODAL -->
    <div class="modal-overlay" id="editModal">
        <div class="modal">
            <button class="close-modal" onclick="closeEditModal()">&#10005;</button>
            <h3>Edit Teacher</h3>
            <div class="form-group"><label>Full Name</label><input type="text" id="e-name" placeholder="Full Name" /></div>
            <div class="form-group"><label>ID</label><input type="text" id="e-id" placeholder="ID Number" /></div>
            <div class="form-group"><label>Subject</label><input type="text" id="e-subject" placeholder="Subject" /></div>
            <div class="form-group">
                <label>Position</label>
                <select id="e-position"><option>Professor</option><option>Instructor</option><option>Associate Professor</option></select>
            </div>
            <div class="form-group">
                <label>Department</label>
                <select id="e-dept"><option>IT</option><option>Engineering</option><option>Science</option><option>Math</option></select>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeEditModal()">Cancel</button>
                <button class="btn-save" onclick="saveEdit()">Update</button>
            </div>
        </div>
    </div>

    <script src="~/js/layout.js"></script>
    <script>
        renderLayout('Teachers');

        var currentPage = 1;
        var rowsPerPage = 10;
        var editIndex = -1;

        function renderTable() {
            var start = (currentPage - 1) * rowsPerPage;
            var slice = window.AMS.teachers.slice(start, start + rowsPerPage);
            document.getElementById('tableBody').innerHTML = slice.map(function(t, i) {
                var gi = start + i;
                return '<tr><td>' + t.name + '</td><td>' + t.id + '</td><td>' + t.subject + '</td><td><strong>' + t.position + '</strong></td><td><strong>' + t.dept + '</strong></td>' +
                    '<td style="display:flex;gap:4px;align-items:center;">' +
                    '<button class="edit-btn" onclick="openEditModal(' + gi + ')"><img src="/Assets/edit_icon.png" alt="edit" /></button>' +
                    '<button class="delete-btn" onclick="deleteRow(' + gi + ')"><img src="/Assets/delete_icon.png" alt="delete" /></button>' +
                    '</td></tr>';
            }).join('');
            var total = Math.max(1, Math.ceil(window.AMS.teachers.length / rowsPerPage));
            document.getElementById('pageInfo').textContent = 'Page ' + currentPage + ' / ' + total;
        }

        function deleteRow(idx) {
            if (confirm('Delete this teacher?')) {
                window.AMS.teachers.splice(idx, 1);
                renderTable();
            }
        }

        function openEditModal(idx) {
            editIndex = idx;
            var t = window.AMS.teachers[idx];
            document.getElementById('e-name').value = t.name;
            document.getElementById('e-id').value = t.id;
            document.getElementById('e-subject').value = t.subject;
            document.getElementById('e-position').value = t.position;
            document.getElementById('e-dept').value = t.dept;
            document.getElementById('editModal').classList.add('open');
        }

        function closeEditModal() { document.getElementById('editModal').classList.remove('open'); }

        function saveEdit() {
            var name = document.getElementById('e-name').value.trim();
            var id = document.getElementById('e-id').value.trim();
            var subject = document.getElementById('e-subject').value.trim();
            var position = document.getElementById('e-position').value;
            var dept = document.getElementById('e-dept').value;
            if (!name || !id || !subject) { alert('Please fill all fields.'); return; }
            window.AMS.teachers[editIndex] = { name: name, id: id, subject: subject, position: position, dept: dept };
            renderTable();
            closeEditModal();
        }

        function prevPage() { if (currentPage > 1) { currentPage--; renderTable(); } }
        function nextPage() {
            var total = Math.ceil(window.AMS.teachers.length / rowsPerPage);
            if (currentPage < total) { currentPage++; renderTable(); }
        }

        function openModal() { document.getElementById('modal').classList.add('open'); }
        function closeModal() { document.getElementById('modal').classList.remove('open'); }

        function addTeacher() {
            var name = document.getElementById('m-name').value.trim();
            var id = document.getElementById('m-id').value.trim();
            var subject = document.getElementById('m-subject').value.trim();
            var position = document.getElementById('m-position').value;
            var dept = document.getElementById('m-dept').value;
            if (!name || !id || !subject) { alert('Please fill all fields.'); return; }
            window.AMS.teachers.push({ name: name, id: id, subject: subject, position: position, dept: dept });
            renderTable();
            closeModal();
            document.getElementById('m-name').value = '';
            document.getElementById('m-id').value = '';
            document.getElementById('m-subject').value = '';
        }

        renderTable();
    </script>
</body>
</html>