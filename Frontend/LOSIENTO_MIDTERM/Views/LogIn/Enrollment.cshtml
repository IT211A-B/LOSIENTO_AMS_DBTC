<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Enrollment - AMS</title>
    <link rel="stylesheet" href="~/css/styles.css" />
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar" id="sidebar"></aside>
        <div class="main-content">
            <div class="topbar" id="topbar"></div>
            <div class="page-content">

                <div class="table-header">
                    <div>
                        <h2 id="enr-title">Students</h2>
                        <div class="subtitle" id="enr-sub">Bachelor of Science in Mechanical Engineering</div>
                    </div>
                    <button class="btn-add" onclick="openModal()">ADD</button>
                </div>

                <div class="tab-row">
                    <button class="tab-btn active" id="tab-bsit" onclick="switchTab('BSIT')">BSIT</button>
                    <button class="tab-btn" id="tab-bsme" onclick="switchTab('BSME')">BSME</button>
                </div>

                <table class="data-table">
                    <thead><tr id="tableHead"></tr></thead>
                    <tbody id="tableBody"></tbody>
                </table>
                <div class="pagination">
                    <button onclick="prevPage()">&#60;</button>
                    <span id="pageInfo">Page 1</span>
                    <button onclick="nextPage()">&#62;</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ADD MODAL -->
    <div class="modal-overlay" id="modal">
        <div class="modal">
            <button class="close-modal" onclick="closeModal()">&#10005;</button>
            <h3>Add Enrollment</h3>
            <div class="form-group"><label>Student Name</label><input type="text" id="m-name" placeholder="Full Name" /></div>
            <div class="form-group"><label>Student ID</label><input type="text" id="m-id" placeholder="ID Number" /></div>
            <div class="form-group"><label>Subject</label><input type="text" id="m-course" placeholder="Subject name" /></div>
            <div class="form-group">
                <label>Program</label>
                <select id="m-program"><option value="BSIT">BSIT</option><option value="BSME">BSME</option></select>
            </div>
            <div class="form-group">
                <label>Status</label>
                <select id="m-status"><option>Enrolled</option><option>Pending</option><option>Dropped</option></select>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeModal()">Cancel</button>
                <button class="btn-save" onclick="addEnrollment()">Save</button>
            </div>
        </div>
    </div>

    <!-- EDIT MODAL -->
    <div class="modal-overlay" id="editModal">
        <div class="modal">
            <button class="close-modal" onclick="closeEditModal()">&#10005;</button>
            <h3>Edit Enrollment</h3>
            <div class="form-group"><label>Student Name</label><input type="text" id="e-name" placeholder="Full Name" /></div>
            <div class="form-group"><label>Student ID</label><input type="text" id="e-id" placeholder="ID Number" /></div>
            <div class="form-group"><label>Subject</label><input type="text" id="e-course" placeholder="Subject name" /></div>
            <div class="form-group">
                <label>Program</label>
                <select id="e-program"><option value="BSIT">BSIT</option><option value="BSME">BSME</option></select>
            </div>
            <div class="form-group">
                <label>Status</label>
                <select id="e-status"><option>Enrolled</option><option>Pending</option><option>Dropped</option></select>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeEditModal()">Cancel</button>
                <button class="btn-save" onclick="saveEdit()">Update</button>
            </div>
        </div>
    </div>

    <script src="~/js/layout.js"></script>
    <script>
        renderLayout('Enrollment');

        var enrollments = {
            BSIT: [
                { name: 'Kenwell Montekun', id: '902182', course: 'Information Management, Lec.', program: 'BSME', status: 'Enrolled' },
                { name: 'Kenwell Montekun', id: '902182', course: 'Web Applications Dev., Lec.', program: 'BSIT', status: 'Dropped' },
                { name: 'Kenwell Montekun', id: '902182', course: 'Information Management, Lec.', program: 'BSIT', status: 'Enrolled' },
                { name: 'Kenwell Montekun', id: '902182', course: 'National Service Training', program: 'BSME', status: 'Pending' },
                { name: 'Kenwell Montekun', id: '902182', course: 'Web Applications Dev., Lab.', program: 'BSME', status: 'Pending' },
                { name: 'Kenwell Montekun', id: '902182', course: 'Network Management 2, Lec.', program: 'BSIT', status: 'Enrolled' },
            ],
            BSME: [
                { name: 'Moreno, Junjun', id: '902182', code: 'IT 210B', subject: 'Information Management, Lec.', program: 'BSME', units: 3 },
                { name: 'Rebese, Choyins', id: '902182', code: 'IT 210A', subject: 'Information Management, Lab.', program: 'BSIT', units: 3 },
                { name: 'Montebon, Kenwell', id: '902182', code: 'IT 211A', subject: 'Web Applications Dev., Lec.', program: 'BSIT', units: 3 },
                { name: 'Kenwell Montekun', id: '902182', code: 'IT 211B', subject: 'Web Applications Dev., Lab.', program: 'BSME', units: 3 },
            ]
        };

        var currentTab = 'BSIT', currentPage = 1, rowsPerPage = 10, editIndex = -1;

        var courseNames = { BSIT: 'Bachelor of Science in Information Technology', BSME: 'Bachelor of Science in Mechanical Engineering' };

        function scls(s) { return s === 'Enrolled' ? 'status-enrolled' : s === 'Dropped' ? 'status-dropped' : 'status-pending'; }

        function switchTab(tab) {
            currentTab = tab; currentPage = 1;
            document.getElementById('tab-bsit').classList.toggle('active', tab === 'BSIT');
            document.getElementById('tab-bsme').classList.toggle('active', tab === 'BSME');
            document.getElementById('enr-sub').textContent = courseNames[tab];
            renderTable();
        }

        function renderTable() {
            var data = enrollments[currentTab];
            var start = (currentPage - 1) * rowsPerPage;
            var slice = data.slice(start, start + rowsPerPage);
            var head = document.getElementById('tableHead');
            var tbody = document.getElementById('tableBody');
            if (currentTab === 'BSIT') {
                document.getElementById('enr-title').textContent = 'Students';
                head.innerHTML = '<th>STUDENT</th><th>ID</th><th>SUBJECT</th><th>PROGRAM</th><th>STATUS</th><th></th>';
                tbody.innerHTML = slice.map(function(e, i) {
                    var gi = start + i;
                    return '<tr><td>' + e.name + '</td><td>' + e.id + '</td><td>' + e.course + '</td><td>' + e.program + '</td><td class="' + scls(e.status) + '">' + e.status + '</td>' +
                        '<td style="white-space:nowrap;">' +
                        '<button class="edit-btn" onclick="openEditModal(' + gi + ')"><img src="/Assets/edit_icon.png" alt="edit" /></button>' +
                        '<button class="delete-btn" onclick="deleteRow(' + gi + ')"><img src="/Assets/delete_icon.png" alt="delete" /></button>' +
                        '</td></tr>';
                }).join('');
            } else {
                document.getElementById('enr-title').textContent = 'Courses';
                head.innerHTML = '<th>STUDENT</th><th>Code</th><th>Subject</th><th>PROGRAM</th><th>UNITS</th><th></th>';
                tbody.innerHTML = slice.map(function(e, i) {
                    var gi = start + i;
                    return '<tr><td>' + e.name + '</td><td>' + e.code + '</td><td>' + e.subject + '</td><td>' + e.program + '</td><td>' + e.units + '</td>' +
                        '<td style="white-space:nowrap;">' +
                        '<button class="edit-btn" onclick="openEditModal(' + gi + ')"><img src="/Assets/edit_icon.png" alt="edit" /></button>' +
                        '<button class="delete-btn" onclick="deleteRow(' + gi + ')"><img src="/Assets/delete_icon.png" alt="delete" /></button>' +
                        '</td></tr>';
                }).join('');
            }
            var total = Math.max(1, Math.ceil(data.length / rowsPerPage));
            document.getElementById('pageInfo').textContent = 'Page ' + currentPage + ' / ' + total;
        }

        function deleteRow(idx) { if (confirm('Delete this record?')) { enrollments[currentTab].splice(idx, 1); renderTable(); } }

        function openEditModal(idx) {
            editIndex = idx;
            var e = enrollments[currentTab][idx];
            if (currentTab === 'BSIT') {
                document.getElementById('e-name').value = e.name;
                document.getElementById('e-id').value = e.id;
                document.getElementById('e-course').value = e.course;
                document.getElementById('e-program').value = e.program;
                document.getElementById('e-status').value = e.status;
            }
            document.getElementById('editModal').classList.add('open');
        }
        function closeEditModal() { document.getElementById('editModal').classList.remove('open'); }
        function saveEdit() {
            var name = document.getElementById('e-name').value.trim();
            var id = document.getElementById('e-id').value.trim();
            var course = document.getElementById('e-course').value.trim();
            var program = document.getElementById('e-program').value;
            var status = document.getElementById('e-status').value;
            if (!name || !id || !course) { alert('Please fill all fields.'); return; }
            enrollments[currentTab][editIndex] = { name: name, id: id, course: course, program: program, status: status };
            renderTable(); closeEditModal();
        }

        function prevPage() { if (currentPage > 1) { currentPage--; renderTable(); } }
        function nextPage() { var t = Math.ceil(enrollments[currentTab].length / rowsPerPage); if (currentPage < t) { currentPage++; renderTable(); } }
        function openModal() { document.getElementById('modal').classList.add('open'); }
        function closeModal() { document.getElementById('modal').classList.remove('open'); }
        function addEnrollment() {
            var name = document.getElementById('m-name').value.trim();
            var id = document.getElementById('m-id').value.trim();
            var course = document.getElementById('m-course').value.trim();
            var program = document.getElementById('m-program').value;
            var status = document.getElementById('m-status').value;
            if (!name || !id || !course) { alert('Please fill all fields.'); return; }
            enrollments['BSIT'].push({ name: name, id: id, course: course, program: program, status: status });
            if (currentTab !== 'BSIT') switchTab('BSIT'); else renderTable();
            closeModal();
            ['m-name', 'm-id', 'm-course'].forEach(function(f) { document.getElementById(f).value = ''; });
        }

        switchTab('BSIT');
    </script>
</body>
</html>